# MENU MADE — environment variables
# Copy this file to .env.local for local development.
# In Vercel, add these in Project Settings → Environment Variables.

# Anthropic API key — for menu extraction + recipe generation
# Get one at https://console.anthropic.com — ~$5 in starter credits goes a long way
ANTHROPIC_API_KEY=sk-ant-...

# Exa API key — for live web search of restaurants
# Get one at https://exa.ai — free tier covers initial testing
EXA_API_KEY=...
